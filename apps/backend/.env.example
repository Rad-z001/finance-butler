# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# comma-separated origins allowed to call the REST API
CORS_ORIGINS=http://localhost:5173

# ── Database / Cache ────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance_butler
REDIS_URL=redis://localhost:6379

# ── LINE (https://developers.line.biz/console) ──────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# LINE Login channel (dashboard auth)
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=http://localhost:3000/api/v1/auth/line/callback

# ── AI (Claude) — OPTIONAL ──────────────────────────────
# Leave empty to run rules-only (no AI fallback for unusual phrasings, no Q&A).
ANTHROPIC_API_KEY=
# model for ambiguous message parsing
AI_PARSE_MODEL=claude-sonnet-5
# cheap model for category classification / OCR structuring
AI_CLASSIFY_MODEL=claude-haiku-4-5-20251001

# ── OCR ─────────────────────────────────────────────────
# google | tesseract
OCR_PROVIDER=google
# path to service-account json (Google Vision)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Storage (S3-compatible; MinIO in dev) ───────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=finance-butler
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Auth ────────────────────────────────────────────────
# openssl rand -hex 64
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
